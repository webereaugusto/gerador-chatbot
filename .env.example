PORT=3000

SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE=sua-service-role-key

# Obrigatorio para API externa (/api/v1/* e geracao de chaves). Use uma string longa e aleatoria.
API_KEY_PEPPER=

# Evolution API gerenciada pelo backend (QR in-app, usuario nao configura nada).
# EVOLUTION_BASE_URL  = URL do seu Evolution no VPS (ex.: https://evolution.seudominio.com)
# EVOLUTION_GLOBAL_API_KEY = valor de AUTHENTICATION_API_KEY do .env do Evolution (chave GLOBAL, nao da instancia).
EVOLUTION_BASE_URL=
EVOLUTION_GLOBAL_API_KEY=
